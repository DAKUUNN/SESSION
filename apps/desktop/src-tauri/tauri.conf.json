{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Session",
  "version": "0.1.0",
  "identifier": "com.peaksense.session",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Session",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBNzZCN0IyRDNGQTg0ODgKUldTSWhQclRzcmQyeWpWb3BzaVZYOGRGa0lrRlI5OU9raWM5dkZNWVJYdUxuNlhoRHY3dlVkL3MK",
      "endpoints": [
        "https://github.com/DAKUUNN/SESSION/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
